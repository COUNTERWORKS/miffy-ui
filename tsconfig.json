{
  "compilerOptions": {
      "outDir": "./public/",
      "sourceMap": true,
      "noImplicitAny": true,
      "module": "commonjs",
      "target": "es6",
      "lib": ["es6", "dom"],
      "jsx": "react",
      "baseUrl": "./",
      "typeRoots": ["src/interfaces"],
      "paths": {
        "@": ["src/*"],
        "components/*": ["src/components/*"],
        "common/*": ["src/common/*"],
        "pages/*": ["src/pages/*"],
        "themes/*": ["resources/src/themes/*"],
      },
  },
  "include": [
      "./src/**/*"
  ]
}
